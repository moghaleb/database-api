# Example env file - DO NOT commit real secrets here
# Copy this to .env and fill with real values in your environment

# Admin credentials (REQUIRED for admin panel access)
ADMIN_USER=admin
ADMIN_PASS=replace_with_a_strong_password

# API token for Bearer authentication on /api/* endpoints (REQUIRED)
# Generate with: openssl rand -hex 32
API_TOKEN=replace_with_a_random_token_value

# Session secret for signed cookies (REQUIRED)
# Generate with: openssl rand -hex 32
SESSION_SECRET=replace_with_a_random_session_secret

# Application port
PORT=3000

# SSL certificate paths (optional, set only if using HTTPS directly)
# SSL_CERT_PATH=/etc/letsencrypt/live/example.com/fullchain.pem
# SSL_KEY_PATH=/etc/letsencrypt/live/example.com/privkey.pem

# Database configuration (only used if switching to MySQL)
# DB_TYPE=mysql
# DB_HOST=mysql
# DB_PORT=3306
# DB_NAME=coupon_db
# DB_USER=coupon_user
# DB_PASSWORD=replace_with_db_password
# DB_ROOT_PASSWORD=replace_with_root_password
